# ─── FocusLock Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real values.
#
# All VITE_ prefixed vars are exposed to the browser.
# Non-prefixed vars are server-side only (Vercel serverless functions).

# ── App ───────────────────────────────────────────────────────────────────────

# The public URL where the webapp is deployed
VITE_APP_URL=https://focuslock.vercel.app

# Your published Chrome Extension ID (auto-detected in dev, needed for prod)
VITE_EXTENSION_ID=

# ── Supabase (get from supabase.com → project → Settings → API) ──────────────

# Project URL — safe to expose to browser
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon/public key — safe to expose (RLS protects data)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER SIDE ONLY, never prefix with VITE_
# Used by Vercel serverless functions to bypass RLS
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Feature Flags ─────────────────────────────────────────────────────────────

VITE_ENABLE_LEADERBOARD=false
VITE_ENABLE_HISTORY=false
